# Server
PORT=4000
NODE_ENV=development

# Database
MONGO_URI=mongodb://127.0.0.1:27017/vibe_id

# Auth
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=30d

# Groq (vision + classification). Get a free key at https://console.groq.com
GROQ_API_KEY=
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
GROQ_TEXT_MODEL=llama-3.3-70b-versatile

# Image generation (Pollinations is free + keyless; leave PROVIDER=pollinations)
IMAGE_PROVIDER=pollinations

# Toggle MOCK_AI=true to bypass Groq + Pollinations and run the full flow
# with deterministic mock data. Useful for local dev and offline testing.
MOCK_AI=false

# Rate limiting (free reads per day for non-premium users)
FREE_DAILY_READS=1

# --- Person matching (optional) ---
# Set PERSON_MATCHING=clip and run scripts/embed-server.py to enable
# anonymous-user dedup: same person, same archetype across photos.
# Logged-in users are always locked in by user identity regardless.
PERSON_MATCHING=off
EMBED_URL=http://127.0.0.1:5050/embed
EMBED_SIM_THRESHOLD=0.92
